# EVE ESI OAuth2 Credentials
# Register your app at https://developers.eveonline.com/
ESI_CLIENT_ID=your_client_id_here
ESI_CLIENT_SECRET=your_client_secret_here
ESI_CALLBACK_URL=http://localhost:8000/callback
ESI_SCOPES=esi-wallet.read_character_wallet.v1 esi-skills.read_skills.v1 esi-markets.read_character_orders.v1

# Character
CHARACTER_ID=your_character_id_here

# Transport Risk
# Manual low-sec hauling risk factor as a decimal fraction of cargo value (e.g. 0.05 = 5%)
TRANSPORT_RISK_FACTOR=0.05

# Region
# The Forge (Jita) = 10000002
MARKET_REGION_ID=10000002
