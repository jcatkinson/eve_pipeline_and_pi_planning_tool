# -----------------------------------------------------------------------
# EVE ESI OAuth2 Credentials
# Register your app at https://developers.eveonline.com/
# -----------------------------------------------------------------------
ESI_CLIENT_ID=your_client_id_here
ESI_CLIENT_SECRET=your_client_secret_here
# Local dev callback — update to https://your-app.streamlit.app/callback for prod
ESI_CALLBACK_URL=http://localhost:8501/callback
# Full scope list — corp wallet scope required for premium verification
ESI_SCOPES=esi-wallet.read_character_wallet.v1 esi-skills.read_skills.v1 esi-markets.read_character_orders.v1 esi-wallet.read_corporation_wallets.v1

# -----------------------------------------------------------------------
# Primary CLI character (used by CLI mode only, not the web app)
# -----------------------------------------------------------------------
CHARACTER_ID=your_character_id_here

# -----------------------------------------------------------------------
# Transport Risk & Market
# -----------------------------------------------------------------------
TRANSPORT_RISK_FACTOR=0.05
# The Forge (Jita) = 10000002
MARKET_REGION_ID=10000002

# -----------------------------------------------------------------------
# Supabase — get these from supabase.com → Settings → API
# -----------------------------------------------------------------------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

# -----------------------------------------------------------------------
# Corp verification (Moonpack Associates)
# Corp API character must have Accountant or Director role
# -----------------------------------------------------------------------
CORP_API_CHARACTER_ID=your_corp_api_character_id
MOONPACK_CORP_ID=your_moonpack_corp_id

# -----------------------------------------------------------------------
# Admin override — owner's primary EVE character ID gets permanent corporate-
# level access displayed as "Admin". Set to 0 to disable.
# -----------------------------------------------------------------------
ADMIN_CHARACTER_ID=0